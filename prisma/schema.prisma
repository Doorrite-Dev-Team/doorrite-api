// ===============================
// Prisma MongoDB Schema
// ===============================

// --- Generators ---
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator jsonSchema {
  provider = "prisma-json-schema-generator"
  output   = "../src"
}

// ===============================
// ENUMS
// ===============================
enum Role {
  CUSTOMER
  ADMIN
}

enum VehicleType {
  MOTORCYCLE
  BIKE
  CAR
  BICYCLE
}

enum OrderStatus {
  PENDING_PAYMENT
  PENDING
  SCHEDULED
  ACCEPTED
  PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  PAYSTACK
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  REFUNDED
  COD
}

enum DeliveryStatus {
  WAITING_PICKUP
  PICKED_UP
  DELIVERING
  DELIVERED
}

enum TransactionType {
  EARNING
  PAYOUT
  BONUS
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
  FAILED
}

enum PayoutStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  FAILED
}

enum PayoutRequestType {
  WEEKLY
  INSTANT
}

enum OtpType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
}

// ===============================
// TYPES
// ===============================
type Address {
  address      String         // Human-readable formatted address
  state        String
  country      String? @default("Nigeria")
  coordinates  Coordinates
}

type ContactInfo {
  fullName      String
  phone         String
  email         String
  instructions  String?
}

type Coordinates {
  lat   Float
  long  Float
}

// ===============================
// MODELS
// ===============================
model User {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  role            Role     @default(CUSTOMER)
  fullName        String
  email           String   @unique
  phoneNumber     String   @unique
  passwordHash    String
  profileImageUrl String?
  isVerified      Boolean  @default(false)
  tokenVersion     Int      @default(0)
  
  // Referral fields
  referralCode        String?  @unique
  referredBy          String?  @db.ObjectId
  freeDeliveryOrders  Int      @default(2)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  address         Address[]
  orders          Order[]   @relation("customer_orders")
  payments        Payment[]
  reviews         Review[]
  favorites       Favorite[]
  referralsMade   Referral[] @relation("ReferrerReferences")
  referralsReceived Referral[] @relation("RefereeReferences")
}

model Vendor {
  id                  String      @id @default(auto()) @map("_id") @db.ObjectId
  email               String      @unique
  businessName        String      @unique
  phoneNumber         String      @unique
  passwordHash        String
  logoUrl             String?
  rating              Float?
  reviewCount         Int         @default(0)
  openingTime         String?  // e.g. "09:00 AM"
  closingTime         String?  // e.g. "09:00 PM"
  avrgPreparationTime String?  // e.g. "20-30 mins"
  isActive            Boolean     @default(true)
  isVerified          Boolean     @default(false)
  isApproved          Boolean     @default(false)
  tokenVersion         Int          @default(0)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  address             Address
  categories          String[]

  // Relations
  products            Product[]
  orders              Order[]
  reviews             Review[]
  modifierGroups ModifierGroup[]
  wallet              Wallet?
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  vendorId    String   @db.ObjectId
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  name        String
  description String?
  basePrice   Float
  sku         String?
  imageUrl    String?
  attributes  Json?    // e.g. {"weight":"500g","unit":"g"}
  rating      Float?
  reviewCount Int      @default(0)
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants    ProductVariant[]
  orderItems  OrderItem[]
  reviews     Review[]
  productReviews ProductReview[]
  modifierGroups ProductModifierGroup[]
}

model ProductVariant {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productId   String   @db.ObjectId
  product     Product  @relation(fields: [productId], references: [id])
  name        String
  price       Float
  stock       Int?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]
}

model Rider {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  fullName        String
  email           String      @unique
  phoneNumber     String      @unique
  passwordHash    String
  vehicleType     VehicleType @default(BICYCLE)
  profileImageUrl String?
  licenseNumber   String?
  isAvailable     Boolean     @default(true)
  isVerified      Boolean     @default(false)
  isApproved      Boolean     @default(false)
  tokenVersion     Int          @default(0)
  rating          Float?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  address    Address?
  deliveries Delivery[]
  orders     Order[]    @relation("rider_orders")
  reviews    Review[]
  wallet     Wallet?
  earningsRecords EarningsRecord[]
}

model Order {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  customerId String @db.ObjectId
  customer User @relation("customer_orders", fields: [customerId], references: [id])
  vendorId String @db.ObjectId
  vendor Vendor @relation(fields: [vendorId], references: [id])
  riderId String? @db.ObjectId
  rider Rider? @relation("rider_orders", fields: [riderId], references: [id])
  contactInfo ContactInfo
  status OrderStatus @default(PENDING)
  deliveryAddress Address
  deliveryVerificationCode String?
  totalAmount Float
  paymentStatus PaymentStatus @default(PENDING)
  placedAt DateTime @default(now())
  deliveredAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reorderCount Int @default(0)
  originalOrderId String? @db.ObjectId
  scheduledAt DateTime?

  items OrderItem[]
  payment Payment?
  delivery Delivery?
  history OrderHistory[]
  earningsRecord EarningsRecord?
  review Review?
  messages Message[]
}

model OrderItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId    String   @db.ObjectId
  order      Order    @relation(fields: [orderId], references: [id])
  productId  String   @db.ObjectId
  product    Product  @relation(fields: [productId], references: [id])
  variantId  String?  @db.ObjectId
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  quantity   Int
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  modifiers      OrderItemModifier[]
  modifiersTotal Float   @default(0)  // Sum of modifier adjustments
}

model Payment {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  orderId       String        @unique @db.ObjectId
  order         Order         @relation(fields: [orderId], references: [id])
  userId        String        @db.ObjectId
  user          User          @relation(fields: [userId], references: [id])
  amount        Float
  method        PaymentMethod
  transactionId String?
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Delivery {
  id                    String         @id @default(auto()) @map("_id") @db.ObjectId
  orderId               String         @unique @db.ObjectId
  order                 Order          @relation(fields: [orderId], references: [id])
  riderId               String         @db.ObjectId
  rider                 Rider          @relation(fields: [riderId], references: [id])
  pickupLocation        Json
  dropoffLocation       Json
  status                DeliveryStatus @default(WAITING_PICKUP)
  estimatedDeliveryTime DateTime?
  actualDeliveryTime    DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  rating    Int
  comment   String?
  orderId   String   @unique @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  productId String? @db.ObjectId
  vendorId  String? @db.ObjectId
  riderId   String? @db.ObjectId

  product        Product?        @relation(fields: [productId], references: [id])
  vendor         Vendor?         @relation(fields: [vendorId], references: [id])
  rider          Rider?          @relation(fields: [riderId], references: [id])
  order          Order?          @relation(fields: [orderId], references: [id])
  productReviews ProductReview[]
}

model ProductReview {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  reviewId  String  @db.ObjectId
  review    Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  productId String  @db.ObjectId
  product   Product @relation(fields: [productId], references: [id])
  rating    Int

  @@index([productId])
  @@index([reviewId])
}

model Favorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())

  userId    String @db.ObjectId
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String @db.ObjectId

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model OrderHistory {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String      @db.ObjectId
  order     Order       @relation(fields: [orderId], references: [id])
  status    OrderStatus
  actorId   String?     @db.ObjectId
  actorType String?     // "VENDOR" | "RIDER" | "SYSTEM" | "ADMIN"
  note      String?
  createdAt DateTime    @default(now())
}

// ===============================
// MODIFIER SYSTEM (MVP)
// ===============================

// Reusable modifier group template
model ModifierGroup {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  vendorId    String   @db.ObjectId
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  name        String   // e.g., "Size", "Protein Options"
  isRequired  Boolean  @default(false)
  minSelect   Int      @default(0)  // 0 = optional
  maxSelect   Int      @default(1)  // 1 = single choice, >1 = multiple

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  options             ModifierOption[]
  productAssignments  ProductModifierGroup[]

  @@index([vendorId])
}

// Options within a modifier group
model ModifierOption {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  modifierGroupId String        @db.ObjectId
  group           ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  name            String        // e.g., "Chicken", "Large"
  priceAdjustment Float         @default(0)  // Can be positive or negative
  isAvailable     Boolean       @default(true)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  orderItemModifiers OrderItemModifier[]

  @@index([modifierGroupId])
}

// Links products to modifier groups
model ProductModifierGroup {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  productId       String        @db.ObjectId
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroupId String        @db.ObjectId
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([productId, modifierGroupId])
  @@index([productId])
  @@index([modifierGroupId])
}

// Tracks selected modifiers in an order
model OrderItemModifier {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  orderItemId     String         @db.ObjectId
  orderItem       OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  modifierOptionId String        @db.ObjectId
  modifierOption   ModifierOption @relation(fields: [modifierOptionId], references: [id])

  // Snapshot data at order time
  groupName       String  // e.g., "Size"
  optionName      String  // e.g., "Large"
  priceAdjustment Float   // Snapshot of price

  quantity        Int     @default(1)  // For "2x Extra Cheese"

  createdAt       DateTime @default(now())

  @@index([orderItemId])
}

// ===============================
// WALLET MODEL
// ===============================
model Wallet {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  balance         Float    @default(0)
  pendingBalance  Float    @default(0)
  totalEarned     Float    @default(0)
  totalWithdrawn  Float    @default(0)
  lastUpdated     DateTime @updatedAt
  createdAt       DateTime @default(now())

  ownerId   String @unique @db.ObjectId
  ownerType String // "RIDER" | "VENDOR"

  vendor    Vendor? @relation(fields: [ownerId], references: [id])
  rider     Rider?  @relation(fields: [ownerId], references: [id])

  transactions    Transaction[]
  earningsRecords EarningsRecord[]
  payoutSchedules PayoutSchedule[]

  @@index([ownerId, ownerType])
}

model Transaction {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  type        TransactionType
  amount      Float
  description String
  reference   String?
  orderId     String?          @db.ObjectId
  breakdown   Json?
  status      TransactionStatus @default(COMPLETED)
  createdAt   DateTime         @default(now())

  walletId    String           @db.ObjectId
  wallet      Wallet           @relation(fields: [walletId], references: [id])

  payoutSchedule PayoutSchedule?

  @@index([walletId, createdAt])
  @@index([orderId])
}

model EarningsRecord {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId

  riderId         String    @db.ObjectId
  rider           Rider     @relation(fields: [riderId], references: [id])

  orderId         String    @unique @db.ObjectId
  order           Order     @relation(fields: [orderId], references: [id])

  walletId        String    @db.ObjectId
  wallet          Wallet    @relation(fields: [walletId], references: [id])

  baseFee         Float
  distanceFee     Float
  distanceKm      Float
  peakMultiplier  Float     @default(1.0)
  subtotal        Float
  platformFee     Float
  riderEarnings   Float
  waitTimeMinutes Int       @default(0)
  waitTimeFee     Float     @default(0)

  completedAt     DateTime

  createdAt       DateTime  @default(now())

  @@index([riderId, completedAt])
  @@index([walletId])
}

model PayoutSchedule {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  amount          Float
  requestType     PayoutRequestType @default(WEEKLY)
  status          PayoutStatus   @default(PENDING)

  scheduledDate   DateTime
  processedAt     DateTime?

  bankName        String?
  accountNumber   String?
  accountName     String?

  adminNotes      String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  walletId        String         @db.ObjectId
  wallet          Wallet         @relation(fields: [walletId], references: [id])

  transactionId   String?        @unique @db.ObjectId
  transaction     Transaction?   @relation(fields: [transactionId], references: [id])

  @@index([walletId, status])
}

model Message {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  content String
  senderId String @db.ObjectId
  senderType String
  orderId String @db.ObjectId
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  isArchived Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([orderId, isArchived])
}

model PushSubscription {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  userType String
  endpoint String @unique
  p256dh String
  auth String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, userType])
  @@index([userType])
}

model Referral {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  referrerId     String   @db.ObjectId
  refereeId      String?  @db.ObjectId
  refereePhone   String
  status         String   @default("pending") // "pending" | "completed" | "cancelled"
  refereeOrderId String?  @db.ObjectId
  referrerOrderId String? @db.ObjectId
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  referrer User @relation("ReferrerReferences", fields: [referrerId], references: [id])
  referee  User? @relation("RefereeReferences", fields: [refereeId], references: [id])

  @@index([referrerId])
  @@index([refereeId])
  @@index([refereePhone])
  @@index([status])
}
